# ============================================================
# RAG Agent — Environment Variables for Vercel Deploy
# ============================================================
# Go to: Vercel Dashboard → Your Project → Settings → Environment Variables
# Add each variable below (select: Production + Preview + Development)

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ycfzxbizxvzflnpayulu.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_O5-z4YSJYrVyabeCCH4-2g_8DyX6wue

# ── OpenAI (required) ────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── HuggingFace (fallback when OpenAI fails) ─────────────────
HF_API_KEY=your_huggingface_api_key_here

# ── Force OpenAI as the AI provider ──────────────────────────
AI_PROVIDER=openai

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=RAG Knowledge Agent
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_TELEMETRY_DISABLED=1
